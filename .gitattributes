* text=auto

*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.bat text eol=crlf

# 라즈베리파이에서 실행되는 파일 — CRLF 로 체크아웃되면 bash/systemd 가
# '\r: command not found' 로 헷갈리게 실패한다. LF 로 못박아 둔다.
*.sh text eol=lf
*.service text eol=lf
*.timer text eol=lf

*.png binary
*.gif binary
*.db binary
*.sqlite3 binary
